# AI Voice Router — API Keys
# Rename this file to credentials.env and fill in your keys.

# Required — get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Optional — ElevenLabs realistic TTS voices (paid)
ELEVEN_API_KEY=
VOICE_ID=

# Optional — Picovoice Porcupine wake-word (free key at console.picovoice.ai)
PICOVOICE_ACCESS_KEY=
