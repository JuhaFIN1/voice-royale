{
    "Name": "Voice Royale",
    "Version": "1.2.2",
    "Author": "Juha Lempiäinen",
    "Description": "Control Voice Royale — real-time speech translation — directly from your Elgato Stream Deck.",
    "Category": "Voice Royale",
    "CategoryIcon": "icons/category",
    "Icon": "icons/plugin",
    "URL": "https://github.com/JuhaFIN1/voice-royale",
    "CodePath": "plugin.js",
    "PropertyInspectorPath": "propertyinspector/index.html",
    "SDKVersion": 2,
    "Software": {
        "MinimumVersion": "5.0"
    },
    "OS": [
        { "Platform": "windows", "MinimumVersion": "10" },
        { "Platform": "mac",     "MinimumVersion": "10.13" }
    ],
    "Actions": [
        {
            "Name": "Record Toggle",
            "UUID": "com.voiceroyale.record.toggle",
            "Icon": "icons/action-record",
            "Tooltip": "Start or stop recording",
            "SupportedInMultiActions": true,
            "States": [
                { "Image": "icons/action-record-off", "Title": "Record" },
                { "Image": "icons/action-record-on",  "Title": "Recording" }
            ]
        },
        {
            "Name": "Wake Listen",
            "UUID": "com.voiceroyale.wake.toggle",
            "Icon": "icons/action-listen",
            "Tooltip": "Toggle wake-word listening",
            "SupportedInMultiActions": true,
            "States": [
                { "Image": "icons/action-listen-off", "Title": "Listen" },
                { "Image": "icons/action-listen-on",  "Title": "Listening" }
            ]
        },
        {
            "Name": "Speak Now",
            "UUID": "com.voiceroyale.speak",
            "Icon": "icons/action-speak",
            "Tooltip": "Translate and speak the last transcript",
            "SupportedInMultiActions": true,
            "States": [
                { "Image": "icons/action-speak", "Title": "Speak" }
            ]
        },
        {
            "Name": "Stop Recording",
            "UUID": "com.voiceroyale.stop",
            "Icon": "icons/action-stop",
            "Tooltip": "Stop recording immediately",
            "SupportedInMultiActions": true,
            "States": [
                { "Image": "icons/action-stop", "Title": "Stop" }
            ]
        },
        {
            "Name": "Switch Language",
            "UUID": "com.voiceroyale.lang",
            "Icon": "icons/action-lang",
            "Tooltip": "Switch translation target language",
            "SupportedInMultiActions": true,
            "States": [
                { "Image": "icons/action-lang", "Title": "Language" }
            ],
            "PropertyInspectorPath": "propertyinspector/lang.html"
        },
        {
            "Name": "Play Soundboard",
            "UUID": "com.voiceroyale.soundboard",
            "Icon": "icons/action-soundboard",
            "Tooltip": "Play a soundboard sound",
            "SupportedInMultiActions": true,
            "States": [
                { "Image": "icons/action-soundboard", "Title": "Sound" }
            ],
            "PropertyInspectorPath": "propertyinspector/soundboard.html"
        },
        {
            "Name": "Next Soundboard Page",
            "UUID": "com.voiceroyale.sb.page.next",
            "Icon": "icons/action-sb-next",
            "Tooltip": "Switch to the next soundboard page",
            "SupportedInMultiActions": false,
            "States": [
                { "Image": "icons/action-sb-next", "Title": "SB Next" }
            ]
        },
        {
            "Name": "Prev Soundboard Page",
            "UUID": "com.voiceroyale.sb.page.prev",
            "Icon": "icons/action-sb-prev",
            "Tooltip": "Switch to the previous soundboard page",
            "SupportedInMultiActions": false,
            "States": [
                { "Image": "icons/action-sb-prev", "Title": "SB Prev" }
            ]
        },
        {
            "Name": "Voice FX Preset",
            "UUID": "com.voiceroyale.fx",
            "Icon": "icons/action-fx",
            "Tooltip": "Apply a Voice FX preset",
            "SupportedInMultiActions": true,
            "States": [
                { "Image": "icons/action-fx", "Title": "FX" }
            ],
            "PropertyInspectorPath": "propertyinspector/fx.html"
        },
        {
            "Name": "TTS Toggle",
            "UUID": "com.voiceroyale.tts.toggle",
            "Icon": "icons/action-tts",
            "Tooltip": "Cycle between TTS backends (Edge TTS / ElevenLabs)",
            "SupportedInMultiActions": true,
            "States": [
                { "Image": "icons/action-tts", "Title": "TTS" }
            ]
        },
        {
            "Name": "Open Settings",
            "UUID": "com.voiceroyale.settings",
            "Icon": "icons/action-settings",
            "Tooltip": "Open Voice Royale settings dialog",
            "SupportedInMultiActions": false,
            "States": [
                { "Image": "icons/action-settings", "Title": "Settings" }
            ]
        }
    ]
}
